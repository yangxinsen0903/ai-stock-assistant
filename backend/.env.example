APP_NAME=AI Stock Assistant API
ENV=dev
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/aistock
JWT_SECRET_KEY=replace_me_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
